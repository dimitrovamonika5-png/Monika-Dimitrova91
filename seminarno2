int zad1(){
int num;
    int maxNum, minNum;
    printf("Vavedi chisla (0 za krai):\n");
    scanf("%d",&num);
    maxNum = num;
    minNum = num;
    while(num != 0){
        scanf("%d",&num);

        if(num == 0)
            break;

        maxNum = max(maxNum, num);
        minNum = min(minNum, num);
}

    printf("Nai-golyamo: %d\n", maxNum);
    printf("Nai-malko: %d\n", minNum);

    return 0;
}

