int zad9(){
int X;
int Y;
int Z;
int workers;
printf("vuvedete ploshta na poleto:");
scanf("%d", &X);
printf("vuvedete kg grozde na edin kvadraten metur");
scanf("%d", &Y);
printf("vuvedetge jelanite litri vino za prodajba");
scanf("%d", &Z);
printf("broi rabotnici na poleto:");
scanf("%d", &workers);
double totalGrapes = X * Y;
double grapesForWine = totalGrapes * 0.4;
double wineProduced = grapesForWine / 2.5;
    printf("Proizvedeno vino: %.2f litra\n", wineProduced);
    if(wineProduced >= Z) {
        printf("Vinoto e dostatuchno za prodan!\n");
        double leftover = wineProduced - Z;
        double perWorker = leftover / workers;
        printf("Ostatak za rabotnitsite: %.2f litra na rabotnik\n", perWorker);
    } else {
        double shortage = Z - wineProduced;
        printf("Nedostatuchno vino! Otnema se: %.2f litra\n", shortage);
    }
    return 0;
}

