int zadacha3(){
    FILE *in, *bin;
    char word[50];
    char selected[100][50];
    int count = 0;
    printf("Vuvedi dumi v input.txt (po 1 duma ili razdeleni s interval)\n");
    in = fopen("input.txt", "r");
    if (in == NULL) {
        printf("Greshka pri otvorqne na input.txt!\n");
        return 1;
    }
    if (fscanf(in, "%49s", word) != 1) {
        printf("Failat e prazen!\n");
        fclose(in);
        return 1;
    }
    strcpy(selected[count++], word);
    while (fscanf(in, "%49s", word) == 1) {
        if (count == 0) continue;
        char last = selected[count - 1][strlen(selected[count - 1]) - 1];
        if (tolower(word[0]) == tolower(last)) {
            strcpy(selected[count++], word);
        }
    }
    fclose(in);
    bin = fopen("output.bin", "wb");
    if (bin == NULL) {
        printf("Greshka pri zapis v output.bin!\n");
        return 1;
    }
    for (int i = 0; i < count; i++) {
        fwrite(selected[i], sizeof(char), strlen(selected[i]), bin);
        fputc(' ', bin);
    }
    fclose(bin);
    bin = fopen("output.bin", "rb");
    if (bin == NULL) {
        printf("Greshka pri chetene na output.bin!\n");
        return 1;
    }
    printf("Sadarjanie na faila:\n");
    int ch;
    while ((ch = fgetc(bin)) != EOF) {
        putchar(ch);
    }
fclose(bin);
printf("\n");
return 0;
}


