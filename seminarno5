int zadacha5(){
char word[] = "concatenation";  
int len = strlen(word);
char guessed[100];
int usedLetters = 0;
int found = 0;
for (int i = 0; i < len; i++) {
    guessed[i] = '_';
    }
guessed[len] = '\0';
printf("IGRA BESENICA\n");
    while (found < len) {
        printf("\nDuma: %s\n", guessed);
        char letter;
        printf("Vuvedi bukva: ");
        scanf(" %c", &letter);
        letter = tolower(letter);
        usedLetters++;
        int correct = 0;
        for (int i = 0; i < len; i++) {
            if (tolower(word[i]) == letter && guessed[i] == '_') {
                guessed[i] = word[i];
                correct = 1;
                found++;
            }
        }
        if (correct) {
            printf("Poznata bukva!\n");
        } else {
            printf("Nqma takava bukva.\n");
        }
    }
    printf("\nBRAVO! Duma: %s\n", word);
    printf("Vavedeni bukvi: %d\n", usedLetters);
    printf("Limit za pobeda: %d\n", len + 2);
    if (usedLetters <= len + 2) {
        printf("PODWINI! PECHELISH!\n");
    } else {
        printf("Zagubi - prekaleno mnogo opiti.\n");
    }
return 0;
}

