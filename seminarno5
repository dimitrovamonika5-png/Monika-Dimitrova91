int isAnagram(char s1[], char s2[]) {
int count[26] = {0};
    if (strlen(s1) != strlen(s2)) {
        return 0;
    }
for (int i = 0; s1[i] != '\0'; i++) {
    char c = tolower(s1[i]);
        count[c - 'a']++;
    }
for (int i = 0; s2[i] != '\0'; i++) {
    char c = tolower(s2[i]);
        count[c - 'a']--;
    }
for (int i = 0; i < 26; i++) {
    if (count[i] != 0) {
        return 0;
        }
    }
    return 1;
}

typedef struct {
int id;
float hourlyRate;
int hours;
float salary;
} Worker;

void calculateSalary(Worker *w) {
    int normalHours = 40;
    float gross;
    if (w->hours <= normalHours) {
        gross = w->hours * w->hourlyRate;
    } else {
        int overtime = w->hours - normalHours;
        gross = normalHours * w->hourlyRate +
                overtime * w->hourlyRate * 1.5;
    }
    w->salary = gross - (gross * 0.0365); 
}
void addWorker() {
    FILE *f = fopen("workers.dat", "ab");
    if (f == NULL) {
        printf("Greshka pri otvarqne na fail!\n");
        return;
    }
    Worker w;
    printf("Vuvedi ID: ");
    scanf("%d", &w.id);
    printf("Pochasovo zaplashtane: ");
    scanf("%f", &w.hourlyRate);
    printf("Broi chasove: ");
    scanf("%d", &w.hours);
    calculateSalary(&w);
    fwrite(&w, sizeof(Worker), 1, f);
    fclose(f);
    printf("Satrudnik dobaven uspeshno!\n");
}
void showWorkers() {
FILE *f = fopen("workers.dat", "rb");
if (f == NULL) {
printf("Nyama danni!\n");
   return;
    }
Worker w;
printf("\n--- Satrudnici ---\n");
while (fread(&w, sizeof(Worker), 1, f)) {
    printf("ID: %d | Zaplata: %.2f\n", w.id, w.salary);
    }
fclose(f);
}
int countWorkers() {
    FILE *f = fopen("workers.dat", "rb");
    if (f == NULL) return 0;
Worker w;
int count = 0;
while (fread(&w, sizeof(Worker), 1, f)) {
        count++;
    }
fclose(f);
return count;
}


