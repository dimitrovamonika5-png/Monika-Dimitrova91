int zad5() {
    int a[100];
    int n = 0; 
    int command;
    int x;
    printf("Vuvedete komandi: (1 add, 2 delete, 3 smallest, 0 exit)\n");
    while(1){
        scanf("%d", &command);
        if(command == 0) break;
        scanf("%d", &x);
        if(command == 1){ 
            a[n++] = x;
        }
        else if(command == 2){
            int i = 0;
            while(i < n){
                if(a[i] == x){
                    for(int j = i; j < n-1; j++)
                        a[j] = a[j+1];
                    n--;
                } else {
                    i++;
                }
            }
        }
        else if(command == 3){
            if(x > n){
                printf("Nqma elementi\n");
                continue;
            }
            int temp[100];
            for(int i=0;i<n;i++) temp[i]=a[i];
            for(int i=0;i<n-1;i++)
                for(int j=i+1;j<n;j++)
                    if(temp[i]>temp[j]){
                        int t=temp[i]; temp[i]=temp[j]; temp[j]=t;
                    }
            printf("%d\n", temp[x-1]);
        }
    }
    return 0;
}



int zad6(){
int n;
printf("Vuvedete broy elementi: ");
scanf("%d", &n);
int *arr = (int*)malloc(n * sizeof(int));
printf("Vuvedete elementite: ");
    for(int i=0;i<n;i++)
        scanf("%d", &arr[i]);
int *primes = (int*)malloc(n * sizeof(int));
int primeCount=0;
int nonPrimeCount=0;
    for(int i=0;i<n;i++){
        if(isPrime(arr[i])){
            primes[primeCount++] = arr[i];
        } else {
            arr[nonPrimeCount++] = arr[i];
        }
    }
    printf("Masiv bez prosti chisla: ");
    for(int i=0;i<nonPrimeCount;i++)
        printf("%d ", arr[i]);
    printf("\n");
    printf("Masiv s prosti chisla: ");
    for(int i=0;i<primeCount;i++)
        printf("%d ", primes[i]);
    printf("\n");
    free(arr);
    free(primes);
    return 0;
}



int zad7(){ 
int n;
int m;
printf("Vuvedete broy redove i koloni: ");
scanf("%d %d", &n, &m);
    if(n<3 || m<3){
        printf("Matrica trqbva da e ponqkoga 3x3 ili po-golyama\n");
        return 0;
    }
    int mat[n][m];
    printf("Vuvedete elementite na matricata:\n");
    for(int i=0;i<n;i++)
        for(int j=0;j<m;j++)
            scanf("%d",&mat[i][j]);
    int maxSum = -1000000;
    int maxRow = 0, maxCol = 0;
    for(int i=0;i<=n-3;i++){
        for(int j=0;j<=m-3;j++){
            int sum=0;
            for(int r=0;r<3;r++)
                for(int c=0;c<3;c++)
                    sum += mat[i+r][j+c];
            if(sum > maxSum){
                maxSum = sum;
                maxRow = i;
                maxCol = j;
            }
        }
    }
    printf("Podmatrica 3x3 s maksimalna suma:\n");
    for(int r=0;r<3;r++){
        for(int c=0;c<3;c++)
            printf("%d ", mat[maxRow+r][maxCol+c]);
        printf("\n");
    }
    return 0;
}



int zad8(){ 
    int n = 10;
    int *arr = (int*)malloc(n * sizeof(int));
    printf("Vuvedete 10 chisla: ");
    for(int i=0;i<10;i++)
        scanf("%d",&arr[i]);
    int num, pos;
    while(1){
        scanf("%d",&num);
        if(num==0) break;
        scanf("%d",&pos);
        n++;
        arr = (int*)realloc(arr, n * sizeof(int));
        for(int i=n-1;i>pos;i--)
            arr[i] = arr[i-1];
        arr[pos] = num;
    }
    for(int i=0;i<n;i++)
        printf("%d ", arr[i]);
    printf("\n");

    free(arr);
    return 0;}

