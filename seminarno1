int zadacha16(){
    int N;          
    double M;        
    double exchangeRate;
    printf("Vuvedete sredno dni na rabota v mesec (N): ");
    scanf("%d", &N);
    printf("Vuvedete sredno prihodi na den v dolari (M): ");
    scanf("%lf", &M);
    printf("Vuvedete kurs na dolara spryamo leva: ");
    scanf("%lf", &exchangeRate);
    double monthlyIncome = N * M;
    double yearlyIncome = monthlyIncome * 12;
    double bonus = 2.5 * monthlyIncome;
    double totalIncome = yearlyIncome + bonus;
    double netIncome = totalIncome * 0.75;
    double netIncomeBGN = netIncome * exchangeRate;
    double averagePerDay = netIncomeBGN / 365;
    printf("%lf\n", averagePerDay);

    return 0;
}
