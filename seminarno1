    int y2;
    int width;
    int height;
    int area;

    printf("Vuvedete x1 y1 (tochka A): ");
    scanf("%d %d", &x1, &y1);
    printf("Vuvedete x2 y2 (tochka B): ");
    scanf("%d %d", &x2, &y2);
    width = x2 - x1;
    if (width < 0) width = -width;
    height = y2 - y1;
    if (height < 0) height = -height;
    area = width * height;
    printf("Liceto na pravougulnika e: %d\n", area);
    return 0;
}

int zadacha12(){
    int x1;
    int y1;
    int x2;
    int y2;
    int x3;
    int y3;
    int area2;
    int area;
    printf("Vuvedete x1, y1 (tochka A): ");
    scanf("%d %d", &x1, &y1);
    printf("Vuvedete x2, y2 (tochka B): ");
    scanf("%d %d", &x2, &y2);
    printf("Vuvedete x3, y3 (tochka C): ");
    scanf("%d %d", &x3, &y3);
    area2 = x1*(y2 - y3) + x2*(y3 - y1) + x3*(y1 - y2);
    if(area2 < 0) area2 = -area2;
    area = area2 / 2;
    printf("Liceto na triagalnika e: %d\n", area);
    return 0;
}


