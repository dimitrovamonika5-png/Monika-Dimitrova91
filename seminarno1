    radiani = gradusi * 3.141592653589793 / 180;

    printf("sin(%.2lf°) = %.4lf\n", gradusi, sin(radiani));
    printf("cos(%.2lf°) = %.4lf\n", gradusi, cos(radiani));
    printf("tan(%.2lf°) = %.4lf\n", gradusi, tan(radiani));
